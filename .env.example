# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# For NeonDB, use the connection string from your Neon dashboard
# Example: postgresql://username:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Authentication
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Application Password (will be hashed automatically)
APP_PASSWORD="your-secure-password-here"
