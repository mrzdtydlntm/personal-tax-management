# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# For NeonDB, use the connection string from your Neon dashboard
# Example: postgresql://username:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Authentication
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Password hashing key (HMAC-SHA512) — keep separate from JWT_SECRET
HASH_SECRET="your-separate-hmac-hashing-secret-key"

# Field-level encryption key (AES-256-GCM) — must be at least 32 characters
# Used to encrypt sensitive Payslip fields (grossSalary, takeHomePay, pph21Deducted, otherDeductions, fileUrl)
ENCRYPTION_KEY="your-32-plus-character-encryption-key"

# SMTP Email (for forgot password emails)
# Works with Gmail, Mailgun, SMTP2GO, Mailtrap, etc.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="your-email@gmail.com"

# App base URL (used for reset password links in emails)
APP_URL="http://localhost:3000"

# Google Analytics Measurement ID
NUXT_PUBLIC_GTAG_ID="G-XXXXXXXXXX"
